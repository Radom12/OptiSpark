# ══════════════════════════════════════════════
# OptiSpark Environment Configuration
# ══════════════════════════════════════════════

# ── Server-Side (Render dashboard) ──
# Required on the backend server only. Never ship to clients.
GEMINI_API_KEY="your_gemini_api_key_here"

# ── Client-Side (optional, for development only) ──
# Override the backend URL when testing against your local or dev server.
# If not set, the client defaults to the production URL.
#
# For local development:
#   OPTISPARK_SERVER_URL="http://localhost:8000"
#
# For dev environment:
#   OPTISPARK_SERVER_URL="https://optispark-dev.onrender.com"
#
# Production (default — no override needed):
#   https://optispark-api.onrender.com
